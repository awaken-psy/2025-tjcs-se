# 数据库配置 - 连接外部MySQL
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=timecapsule_admin
DB_PASSWORD=Markov@2025
DB_DATABASE=timecapsule
DB_ECHO=true

# 应用配置
APP_ENV=production
APP_SECRET_KEY=your-secret-key-change-in-production-2025
APP_DEBUG=true

# 文件上传配置 - Volume挂载到主机Downloads目录
UPLOAD_DIR=/app/uploads

# 多邮箱提供商配置
# QQ邮箱配置（主要邮箱）
QQ_SENDER_EMAIL=
QQ_SENDER_PASSWORD=

# 163邮箱配置（可选）
EMAIL163_SENDER_EMAIL=
EMAIL163_SENDER_PASSWORD=

# Gmail配置（可选）
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_PASSWORD=

# 同济大学邮箱配置（可选）
TONGJI_SENDER_EMAIL=
TONGJI_SENDER_PASSWORD=

# 默认SMTP配置（兼容旧版本）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_SENDER_EMAIL=
SMTP_SENDER_PASSWORD=


# Redis 缓存配置
REDIS_HOST=redis
REDIS_PORT=6379

# 初始管理员配置
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin1
INIT_ADMIN_EMAIL=admin@admin.com
