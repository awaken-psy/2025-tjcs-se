# 生产环境数据库配置
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=timecapsule_admin 
DB_PASSWORD=
DB_DATABASE=timecapsule
DB_ECHO=false

# 应用配置
APP_ENV=production
APP_SECRET_KEY=your-production-secret-key-change-in-production-2025
APP_DEBUG=false

# 文件上传配置
UPLOAD_DIR=/app/uploads

# SMTP邮件配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_SENDER_EMAIL=your_qq@qq.com
SMTP_SENDER_PASSWORD=your_qq_authorization_code