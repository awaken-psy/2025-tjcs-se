# 数据库配置
DB_TYPE=mysql  # mysql 或 sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=timecapsule_user
DB_PASSWORD=timecapsule_password
DB_DATABASE=timecapsule
DB_PATH=/tmp/timecapsule.db  # SQLite数据库路径
DB_ECHO=false  # 是否输出SQL日志

# 应用配置
APP_ENV=development  # development, production, testing
APP_SECRET_KEY=your-secret-key-here
APP_DEBUG=true

# Redis配置（用于缓存和会话）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 文件上传配置
UPLOAD_MAX_SIZE=50MB
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp3,mp4,wav
UPLOAD_STORAGE_PATH=./uploads

# 地理位置服务配置
GEOCODING_API_KEY=your-geocoding-api-key
MAP_PROVIDER=google  # google, baidu, tencent

# 邮件配置（用于通知）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=时光胶囊·校园
SMTP_FROM_EMAIL=noreply@timecapsule.campus